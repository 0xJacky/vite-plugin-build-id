{
  "name": "vite-plugin-build-id",
  "type": "module",
  "version": "0.7.0",
  "description": "Automatically generates build_id after production compiled",
  "author": {
    "name": "0xJacky",
    "url": "https://jackyu.cn"
  },
  "contributors": [
    {
      "name": "Hintay",
      "url": "https://kugeek.com"
    }
  ],
  "license": "MIT",
  "keywords": [
    "vite-plugin"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
