    "test": "pnpm -s build:test && node --test"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "picocolors": "^1.1.1",
    "rollup": "4.24.3",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.0"
  }
